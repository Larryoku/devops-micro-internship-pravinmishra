{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "./.claude/pre-tool-guard.sh", "shell": "bash" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "./.claude/post-tool-logger.sh", "shell": "bash" }
        ]
      }
    ]
  }
}