# Local .terraform directories
**/.terraform/*

# State files (should live in remote backend)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable files with real values
*.tfvars
*.tfvars.json
!*.tfvars.example

# CLI configuration and plan output
.terraformrc
terraform.rc
*.tfplan

# Lock file is committed by convention; uncomment to ignore.
# .terraform.lock.hcl
